// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique(map: "email") @db.VarChar(255)
  name      String    @db.VarChar(100)
  gender    String    @db.VarChar(15)
  birth     DateTime  @db.Date
  address   String    @db.VarChar(255)
  phoneNum  String    @map("phone_num") @db.VarChar(15)
  userFavorCategories UserFavorCategory[]
  reviews   Review[]
  memberMission MemberMission[]

  @@map("member")
}

model Region {
  id        Int     @id @default(autoincrement())
  name      String  @db.VarChar(20)
  stores     Store[] 
}

model Store {
  id        Int       @id @default(autoincrement())
  name      String    @db.Char(20)
  address   String    @db.VarChar(255)
  region    Region    @relation(fields: [regionId],references: [id])
  regionId  Int       @map("region_id")
  foodCategory  FoodCategory  @relation(fields: [foodCategoryId], references: [id])
  foodCategoryId  Int @map("food_category_id")
  reviews   Review[]
  missions  Mission[]
}

model Mission {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(20)
  body      String    @db.Char(255)
  reward    Int       @db.Int
  deadline  DateTime? @db.Date
  bossNum   Int?      @db.Int
  store     Store     @relation(fields: [storeId],references: [id])
  storeId   Int       @map("store_id")
  memberMission MemberMission[]
}

model Review{
  id        Int       @id @default(autoincrement())
  body      String    @db.Char(255)
  rate      Int       @db.Int
  user      User      @relation(fields: [userId],references: [id])
  userId    Int       @map("user_id")
  store     Store     @relation(fields: [storeId],references: [id])
  storeId   Int       @map("store_id")
}

model MemberMission{
  id        Int     @id @default(autoincrement())
  status    status
  user      User    @relation(fields: [userId],references: [id])
  userId    Int     @map("user_id")
  mission   Mission @relation(fields: [missionId],references: [id])
  missionId Int     @map("mission_id")

  @@map("member_mission")
}

model FoodCategory {
  id    Int     @id @default(autoincrement())
  name  String  @db.VarChar(100)
  userFavorCategories UserFavorCategory[]
  stores  Store[]

  @@map("food_category")
}

model UserFavorCategory{
  id      Int     @id @default(autoincrement())
  user    User    @relation(fields: [userId], references: [id])
  userId  Int    @map("user_id")
  foodCategory  FoodCategory  @relation(fields:[foodCategoryId], references:[id])
  foodCategoryId  Int   @map("food_category_id")

  @@index([foodCategoryId], map:"food_category_id")
  @@index([userId], map: "user_id")
  @@map("member_preference")
}

enum status {
  SUCCESS
  CHALLENGING
}